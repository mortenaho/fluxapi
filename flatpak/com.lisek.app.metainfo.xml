<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.lisek.app</id>
  <name>Lisek</name>
  <summary>Offline API client for HTTP, GraphQL, WebSocket, and gRPC</summary>
  <developer id="ir.mortenaho">
    <name>Seyed Morteza Hosseini</name>
  </developer>
  <url type="homepage">https://mortenaho.github.io/Lisek</url>
  <url type="bugtracker">https://github.com/mortenaho/Lisek/issues</url>
  <url type="vcs-browser">https://github.com/mortenaho/Lisek</url>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>
  <content_rating type="oars-1.1" />
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
  <requires>
    <display_length compare="ge">768</display_length>
  </requires>
  <description>
    <p>
      Lisek is a free, offline desktop API client for HTTP, GraphQL, WebSocket,
      SSE, and gRPC. Build collections, mock local endpoints, run scripts, and
      keep everything on your machine — no cloud account required.
    </p>
    <ul>
      <li>HTTP/REST with auth, cookies, form-data, JSONPath, and cURL import/export</li>
      <li>GraphQL queries, variables, introspection, and subscriptions</li>
      <li>WebSocket, SSE, and gRPC (including reflection)</li>
      <li>Local mock server, environments, history, and scheduled runs</li>
      <li>Import from Postman, Insomnia, Bruno, OpenAPI, and HAR</li>
    </ul>
  </description>
  <launchable type="desktop-id">com.lisek.app.desktop</launchable>
